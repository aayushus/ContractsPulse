{
	"name": "@contractspulse/frontend",
	"private": true,
	"version": "1.0.0",
	"description": "Self-hosted AI contract intelligence platform for legal-grade risk analysis and plain-English clause warnings.",
	"author": "Aayush Mediratta",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aayushus/ContractsPulse.git"
	},
	"keywords": [
		"contract-analysis",
		"legal-tech",
		"pydantic-ai",
		"self-hosted",
		"homelab",
		"sveltekit",
		"fastapi",
		"jwt-auth",
		"risk-assessment",
		"pdf-extraction"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
